{
  "name": "@sab/web",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . && tsc --noemit",
    "db:generate": "prisma generate --config ../../packages/db/prisma.config.ts",
    "db:migrate:dev": "dotenv -e .env -- prisma migrate dev --config ../../packages/db/prisma.config.ts",
    "db:reset": "dotenv -e .env -- prisma migrate reset --config ../../packages/db/prisma.config.ts"
  },
  "dependencies": {
    "@sab/db": "workspace:*",
    "clsx": "^2.1.1",
    "emoji-js": "^3.9.0",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-toastify": "^11.0.5",
    "server-only": "^0.0.1",
    "use-debounce": "^10.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "dotenv-cli": "^7.4.4",
    "@types/emoji-js": "^3.5.2",
    "@types/node": "^24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.8",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
