{
  "name": "slack-archive-browser",
  "version": "^0.3.0",
  "private": true,
  "scripts": {
    "dev": "scripts/start_local_db.sh && next dev ; scripts/stop_local_db.sh",
    "build": "next build",
    "build:vercel": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint . && tsc --noemit",
    "db:local:start": "scripts/start_local_db.sh",
    "db:local:stop": "scripts/stop_local_db.sh",
    "db:reset": "prisma migrate reset",
    "db:migrate:dev": "prisma migrate dev",
    "archive:import": "tsx scripts/archive_to_db.ts .archive",
    "archive:import:test": "tsx scripts/archive_to_db.ts .archive export-test",
    "archive:reset": "scripts/start_local_db.sh && prisma migrate reset && tsx scripts/archive_to_db.ts .archive && scripts/stop_local_db.sh"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "clsx": "^2.1.1",
    "emoji-js": "^3.9.0",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-toastify": "^11.0.5",
    "server-only": "^0.0.1",
    "use-debounce": "^10.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/emoji-js": "^3.5.2",
    "@types/node": "^24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "^24"
  },
  "packageManager": "pnpm@10.26.2+sha512.0e308ff2005fc7410366f154f625f6631ab2b16b1d2e70238444dd6ae9d630a8482d92a451144debc492416896ed16f7b114a86ec68b8404b2443869e68ffda6",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
